{
  "name": "mission-control",
  "version": "0.1.0",
  "description": "Automerge-backed task coordination with CLI, sync server, and UI",
  "type": "module",
  "bin": {
    "mc": "./bin/mc.js"
  },
  "scripts": {
    "sync": "node automerge-sync-server.js",
    "test": "node --test --test-force-exit --test-skip-pattern=\"GAP:\"",
    "test:gaps": "node --test --test-force-exit test/fitness-gaps.test.js test/sync-use-cases.test.js",
    "ui:build": "npm run build --prefix ui-prototype"
  },
  "keywords": [
    "mission-control",
    "automerge",
    "task-tracking"
  ],
  "license": "MIT",
  "dependencies": {
    "@automerge/automerge-repo": "^2.5.1",
    "@automerge/automerge-repo-network-websocket": "^2.5.1",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  }
}
