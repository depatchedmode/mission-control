{
  "name": "mission-control",
  "version": "0.1.0",
  "description": "Automerge-backed task coordination with CLI, sync server, and UI",
  "type": "module",
  "bin": {
    "mc": "./bin/mc.js"
  },
  "scripts": {
    "sync": "node automerge-sync-server.js",
    "test": "node --test test/*.test.js",
    "daemon": "node daemon/index.js",
    "ui:build": "npm run build --prefix ui-prototype",
    "smoke:automerge": "node scripts/smoke/automerge-smoke.js",
    "smoke:cli": "node scripts/smoke/cli-integration-smoke.js",
    "smoke:migrated": "node scripts/smoke/migrated-data-report.js"
  },
  "keywords": [
    "mission-control",
    "automerge",
    "task-tracking"
  ],
  "license": "MIT",
  "dependencies": {
    "@automerge/automerge-repo": "^2.5.1",
    "@automerge/automerge-repo-network-websocket": "^2.5.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "ws": "^8.14.2"
  }
}
